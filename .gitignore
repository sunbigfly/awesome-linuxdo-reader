# Keep the repository focused on source, documentation, and project metadata.
/*
!/.gitignore
!/README.md
!/LICENSE
!/CONTRIBUTING.md
!/SECURITY.md
!/eslint.config.mjs
!/package.json
!/package-lock.json

!/.github/
/.github/*
!/.github/pull_request_template.md
!/.github/ISSUE_TEMPLATE/
/.github/ISSUE_TEMPLATE/*
!/.github/ISSUE_TEMPLATE/config.yml
!/.github/ISSUE_TEMPLATE/bug_report.yml
!/.github/ISSUE_TEMPLATE/feature_request.yml
!/.github/workflows/
!/.github/workflows/*.yml

!/assets/
/assets/*
!/assets/logo.png
!/assets/screenshots/
/assets/screenshots/*
!/assets/screenshots/*.png
/assets/screenshots/manual-*.png

!/docs/
!/docs/**
/docs/superpowers/
/docs/.vitepress/cache/
/docs/.vitepress/dist/

!/scripts/
/scripts/*
!/scripts/userscript-dev
!/scripts/userscript-dev.ps1
!/scripts/validate-docs.mjs

!/tools/
/tools/*
!/tools/userscript-dev/
/tools/userscript-dev/*
!/tools/userscript-dev/Cargo.toml
!/tools/userscript-dev/Cargo.lock
!/tools/userscript-dev/README.md
!/tools/userscript-dev/src/
/tools/userscript-dev/src/*
!/tools/userscript-dev/src/main.rs

!/work/
/work/*
!/work/main.js
